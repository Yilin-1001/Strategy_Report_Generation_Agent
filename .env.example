# RAG评估系统 - 环境变量配置示例
# 复制此文件为 .env 并填入你的API密钥

# ================================
# DeepSeek API - RAG System LLM
# ================================
# 获取方式: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ================================
# GLM (智谱AI) API - 推荐
# ================================
# 获取方式: https://open.bigmodel.cn/
GLM_API_KEY=your-glm-api-key-here

# ================================
# OpenAI API
# ================================
# 获取方式: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ================================
# 通义千问 (阿里云)
# ================================
# 获取方式: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=sk-your-qwen-api-key-here

# ================================
# Azure OpenAI
# ================================
# 获取方式: Azure Portal
AZURE_OPENAI_API_KEY=your-azure-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# ================================
# 其他配置
# ================================
# Milvus配置（如果需要）
MILVUS_HOST=localhost
MILVUS_PORT=19530

# 模型缓存路径
MODEL_CACHE_PATH=./data/models

# 日志级别
LOG_LEVEL=INFO
