# RAG评估系统 - 环境变量配置示例
# 复制此文件为 .env 并填入你的API密钥

# ================================
# DeepSeek API - 主生成模型 (所有Agent节点)
# ================================
# 获取方式: https://platform.deepseek.com/
# 用于: coordinator/researcher/analyst/writer/strategist/archiver
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ================================
# SiliconFlow API - Embedding/Reranker/评审模型
# ================================
# 获取方式: https://cloud.siliconflow.cn/
# 用于: Embedding向量化、Reranker重排序、章节6维度评审、全文5维度评审
SILICONFLOW_API_KEY=your-siliconflow-api-key-here

# ================================
# Milvus 向量数据库
# ================================
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ================================
# 其他配置
# ================================
MODEL_CACHE_PATH=./data/models
LOG_LEVEL=INFO
